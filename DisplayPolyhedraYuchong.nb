Cell[TextData[{
 StyleBox["Draw polyhedron from xyz",
  FontWeight->"Bold"],
 "\n1) Get vertices by extracting Zn-coordinates from xyz"
}], "Text",
 CellChangeTimes->{{3.8921228356784286`*^9, 3.8921228404315577`*^9}, {
  3.89212287504661*^9, 3.892122884163789*^9}, {3.892124033920351*^9, 
  3.892124038763433*^9}},ExpressionUUID->"983b2f60-4887-4987-b078-\
e78d96b2bae3"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Zn1", " ", "=", " ", 
   RowBox[{"Import", "[", 
    RowBox[{"\"\</Users/paulateeuwen/Library/CloudStorage/OneDrive-\
UniversityofCambridge/PhD/Nitschke/Modelling/Mathematica/YuchongCages/Zn-1.\
xyz\>\"", ",", " ", "\"\<Table\>\""}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"metals", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{"\"\<Mn\>\"", ",", " ", "\"\<Fe\>\"", ",", " ", "\"\<Co\>\"", ",",
      " ", "\"\<Ni\>\"", ",", " ", "\"\<Cu\>\"", ",", " ", "\"\<Zn\>\"", ",", 
     " ", "\"\<Pd\>\"", ",", " ", "\"\<Pt\>\"", ",", " ", "\"\<Zr\>\"", ",", 
     " ", "\"\<Na\>\"", ",", " ", "\"\<Mg\>\""}], "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Corners", " ", "=", " ", 
   RowBox[{"Select", "[", 
    RowBox[{"Zn1", ",", " ", 
     RowBox[{
      RowBox[{"MemberQ", "[", 
       RowBox[{"metals", ",", " ", 
        RowBox[{"First", "[", "#", "]"}]}], "]"}], " ", "&"}]}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{"vZn1", " ", "=", " ", 
  RowBox[{
   RowBox[{"Corners", "[", 
    RowBox[{"[", 
     RowBox[{"All", ",", " ", 
      RowBox[{"2", ";;", "4"}]}], "]"}], "]"}], " ", "//", " ", 
   "ToExpression"}]}]}], "Code",
