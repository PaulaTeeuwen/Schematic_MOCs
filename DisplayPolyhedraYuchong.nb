Cell["2-6) Get faces", "Text",
 CellChangeTimes->{{3.892126130860333*^9, 
  3.8921261396874943`*^9}},ExpressionUUID->"a684b024-eb05-4522-940a-\
fa4b77d3a11c"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Zn3Step2", " ", "=", " ", 
   RowBox[{"Import", "[", 
    RowBox[{"\"\</Users/paulateeuwen/Library/CloudStorage/OneDrive-\
UniversityofCambridge/PhD/Nitschke/Modelling/Mathematica/YuchongCages/Zn-3_\
Connections.pdb\>\"", ",", " ", 
     RowBox[{"{", 
      RowBox[{"\"\<PDB\>\"", ",", " ", "\"\<Graphics3D\>\""}], "}"}]}], 
    "]"}]}], ";"}], "\n", 
 RowBox[{"Zn3Step3", " ", "=", " ", 
  RowBox[{"Import", "[", 
   RowBox[{"\"\</Users/paulateeuwen/Library/CloudStorage/OneDrive-\
UniversityofCambridge/PhD/Nitschke/Modelling/Mathematica/YuchongCages/Zn-3_\
Connections2.pdb\>\"", ",", " ", 
    RowBox[{"{", 
     RowBox[{"\"\<PDB\>\"", ",", " ", "\"\<Graphics3D\>\""}], "}"}]}], 
   "]"}]}], "\n", 
 RowBox[{"Zn3Step4", " ", "=", " ", 
  RowBox[{"Import", "[", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"/", "Users"}], "/", "paulateeuwen"}], "/", "Library"}], "/", 
      "CloudStorage"}], "/", "OneDrive"}], "-", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"UniversityofCambridge", "/", "PhD"}], "/", "Nitschke"}], "/",
         "Modelling"}], "/", "Mathematica"}], "/", "YuchongCages"}], "/", 
     "Zn"}], "-", 
    RowBox[{"3", 
     RowBox[{"_Connections2", ".", "pdb"}], "\"\<, \>\"", 
     "Molecule", "\"\<]\nZn3Step5a = MoleculeGraph[Zn3Step4];\nZn3Step5b1 = \
AdjacencyMatrix[Zn3Step5a];\nZn3Step5b2 = AdjacencyMatrix[Zn3Step5a] // \
MatrixForm;\nZn3Step5c = AdjacencyGraph[Zn3Step5b1, DirectedEdges -> False, \
GraphLayout -> \>\"", 
     "PlanarEmbedding", "\"\<, \n             VertexLabels -> \>\"", 
     "Name", "\"\<, ImagePadding -> 5];\n                \nZn3Step5d = \
PlanarGraph[EdgeList[Zn3Step5c], VertexLabels -> \>\"", 
     "Name", "\"\<, PlotTheme -> \>\"", 
     "Classic", "\"\<];\nGraphicsRow[{Zn3Step5a, Zn3Step5b1, Zn3Step5c, \
Zn3Step5d}]\nfZn3 = FindFace[Zn3Step5c]\n\nview[vZn3, fZn3, \
0.8]\>"}]}]}]}]}], "Code",
 CellChangeTimes->{{3.892126157157237*^9, 3.892126201889292*^9}, {
