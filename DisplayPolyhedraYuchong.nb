   3.89443300300523*^9}},ExpressionUUID->"a6ad50b5-0fc3-4286-824b-\
5ccbb0cf40b2"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Zn1Step5a", " ", "=", " ", 
   RowBox[{"MoleculeGraph", "[", "Zn2Step4", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Zn1Step5b1", " ", "=", " ", 
   RowBox[{"AdjacencyMatrix", "[", "Zn1Step5a", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Zn1Step5b2", " ", "=", " ", 
   RowBox[{
    RowBox[{"AdjacencyMatrix", "[", "Zn1Step5a", "]"}], " ", "//", " ", 
    "MatrixForm"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"matrixImage", " ", "=", " ", 
   RowBox[{"Rasterize", "[", 
    RowBox[{"Zn1Step5b2", ",", " ", 
     RowBox[{"Background", " ", "->", " ", "White"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Zn1Step5c", " ", "=", " ", 
    RowBox[{"AdjacencyGraph", "[", 
     RowBox[{"Zn1Step5b1", ",", " ", 
      RowBox[{"DirectedEdges", " ", "->", " ", "False"}], ",", " ", 
      RowBox[{"GraphLayout", " ", "->", " ", "\"\<PlanarEmbedding\>\""}], ",",
       " ", "\n", "             ", 
      RowBox[{"VertexLabels", " ", "->", " ", "\"\<Name\>\""}], ",", " ", 
      RowBox[{"ImagePadding", " ", "->", " ", "5"}]}], "]"}]}], ";"}], "\n", 
  "                "}], "\n", 
 RowBox[{
  RowBox[{"Zn1Step5d", " ", "=", " ", 
   RowBox[{"PlanarGraph", "[", 
    RowBox[{
     RowBox[{"EdgeList", "[", "Zn1Step5c", "]"}], ",", " ", 
     RowBox[{"VertexLabels", " ", "->", " ", "\"\<Name\>\""}], ",", " ", 
     RowBox[{"PlotTheme", " ", "->", " ", "\"\<Classic\>\""}]}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{"GraphicsRow", "[", 
  RowBox[{"{", 
   RowBox[{
   "Zn1Step5a", ",", " ", "matrixImage", ",", " ", "Zn1Step5c", ",", " ", 
    "Zn1Step5d"}], "}"}], "]"}]}], "Code",
 CellChangeTimes->{
  3.892123346186966*^9, {3.892123474345749*^9, 3.892123535229928*^9}, {
   3.892123622366933*^9, 3.892123639663982*^9}, {3.892123675081812*^9, 
   3.892123747362424*^9}, {3.892123928310781*^9, 3.8921239811490993`*^9}, {
