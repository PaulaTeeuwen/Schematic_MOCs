Cell[TextData[{
 "5) Creating a graph from pdb\n\ta) Create a molecular graph: ",
 ButtonBox["LINK",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://www.wolfram.com/language/12/molecular-structure-and-\
computation/molecule-graphs.html.en?product=mathematica#:~:text=Wolfram%\
20Mathematica&text=A%20molecular%20graph%20is%20a,integration%20with%\
20existing%20graph%20functionality"], None},
  ButtonNote->
   "https://www.wolfram.com/language/12/molecular-structure-and-computation/\
molecule-graphs.html.en?product=mathematica#:~:text=Wolfram%20Mathematica&\
text=A%20molecular%20graph%20is%20a,integration%20with%20existing%20graph%\
20functionality"],
 "\n\tb) Obtain adjacency matrix\n\tc) Obtain planar graph\n\td) Display \
nicer planar graph (still ugly though): ",
 ButtonBox["LINK",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://mathematica.stackexchange.com/questions/144594/how-to-plot-\
planar-graphs-in-a-visually-pleasing-way"], None},
  ButtonNote->
   "https://mathematica.stackexchange.com/questions/144594/how-to-plot-planar-\
graphs-in-a-visually-pleasing-way"],
 " "
}], "Text",
 CellChangeTimes->{{3.892123325505177*^9, 3.8921233550737867`*^9}, {
   3.892123498942008*^9, 3.892123515011691*^9}, {3.892123555561555*^9, 
   3.892123575146896*^9}, {3.8921236079472647`*^9, 3.892123615160778*^9}, 
