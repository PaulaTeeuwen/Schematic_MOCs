Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"fZn1", " ", "=", " ", 
   RowBox[{"FindFace", "[", "Zn1Step5c", "]"}]}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"CoordPlanarGraph", " ", "=", " ", 
   RowBox[{"GraphEmbedding", "[", "Zn1Step5c", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"colours", " ", "=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"Hue", "[", "x", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "0", ",", "1", ",", 
       RowBox[{"1", "/", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"Length", "[", "fZn1", "]"}], "-", "1"}], ")"}]}]}], 
      "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"colours2", " ", "=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"RandomColor", "[", "]"}], ",", 
     RowBox[{"Length", "[", "fZn1", "]"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{"Graphics", "[", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"EdgeForm", "[", 
     RowBox[{"Directive", "[", 
      RowBox[{"Black", ",", " ", "Thick"}], "]"}], "]"}], ",", " ", "\n", " ", 
    RowBox[{"Thread", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"colours", " ", "[", 
        RowBox[{"[", 
         RowBox[{";;", " ", 
          RowBox[{"Length", "[", "fZn1", "]"}]}], "]"}], "]"}], ",", " ", 
       "\n", "           ", 
       RowBox[{
        RowBox[{
         RowBox[{"Polygon", "[", 
          RowBox[{"CoordPlanarGraph", "[", 
           RowBox[{"[", "#", "]"}], "]"}], "]"}], " ", "&"}], " ", "/@", " ", 
        "fZn1"}]}], "}"}], "]"}]}], "}"}], "]"}]}], "Code",
