Cell[TextData[{
 "Define a function to obtain faces from a graph: ",
 ButtonBox["LINK",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://mathematica.stackexchange.com/questions/18514/finding-face-\
vertices-from-the-face-adjacency-graph"], None},
  ButtonNote->
   "https://mathematica.stackexchange.com/questions/18514/finding-face-\
vertices-from-the-face-adjacency-graph"]
}], "Text",
 CellChangeTimes->{{3.8921224259703693`*^9, 3.892122437735999*^9}, {
  3.8921810514951468`*^9, 3.8921810555716763`*^9}, {3.892237989307054*^9, 
  3.892238008240534*^9}, {3.892238299487815*^9, 
  3.892238314328455*^9}},ExpressionUUID->"52b88aa4-a80a-4811-bb13-\
b204e76d1bf0"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"nextCandidate", "[", 
     RowBox[{"s_", ",", " ", "t_", ",", " ", "adj_"}], "]"}], " ", ":=", "\n",
     "   ", 
    RowBox[{"Block", "[", 
     RowBox[{
      RowBox[{"{", " ", 
       RowBox[{"length", ",", " ", "pos"}], "}"}], ",", "\n", "      ", 
      RowBox[{
       RowBox[{"length", " ", "=", " ", 
        RowBox[{"Length", "[", "adj", "]"}]}], ";", "\n", "      ", 
       RowBox[{"pos", " ", "=", " ", 
        RowBox[{"Mod", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"Position", "[", 
             RowBox[{"adj", ",", " ", "s"}], "]"}], "[", 
            RowBox[{"[", 
             RowBox[{"1", ",", " ", "1"}], "]"}], "]"}], " ", "+", " ", "1"}],
           ",", " ", "length", ",", " ", "1"}], "]"}]}], ";", "\n", "      ", 
       RowBox[{"{", 
        RowBox[{"t", ",", " ", 
         RowBox[{"adj", "[", 
          RowBox[{"[", "pos", "]"}], "]"}]}], "}"}]}]}], "\n", "    ", 
     "]"}]}], ";"}], "\n", "    "}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"FindFace", "[", 
     RowBox[{"g_", "?", "PlanarGraphQ"}], "]"}], " ", ":=", "\n", "   ", 
    RowBox[{"Block", "[", 
     RowBox[{
      RowBox[{"{", "emb", "}"}], ",", "\n", "      ", 
      RowBox[{
       RowBox[{"emb", " ", "=", " ", 
        RowBox[{"GraphEmbedding", "[", 
         RowBox[{"g", ",", " ", "\"\<PlanarEmbedding\>\""}], "]"}]}], ";", 
       "\n", "      ", 
       RowBox[{"FindFace", "[", 
        RowBox[{"g", ",", " ", "emb"}], "]"}]}]}], "\n", "   ", "]"}]}], 
   ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"FindFace", "[", 
   RowBox[{
    RowBox[{"g_", "?", "PlanarGraphQ"}], ",", " ", "emb_"}], "]"}], " ", ":=",
   "\n", "   ", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "m", ",", " ", "orderings", ",", " ", "pAdj", ",", " ", "rightF", ",", 
      " ", "s", ",", " ", "t", ",", " ", "initial", ",", " ", "face"}], "}"}],
     ",", "\n", "       ", 
    RowBox[{
     RowBox[{"m", " ", "=", " ", 
      RowBox[{"AdjacencyMatrix", "[", "g", "]"}]}], ";", "\n", "       ", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"pAdj", "[", "v", "]"}], " ", "=", " ", "\n", "           ", 
        RowBox[{"SortBy", "[", 
         RowBox[{
          RowBox[{"Pick", "[", 
           RowBox[{
            RowBox[{"VertexList", "[", "g", "]"}], ",", " ", 
            RowBox[{"m", "[", 
             RowBox[{"[", "v", "]"}], "]"}], ",", " ", "1"}], "]"}], ",", " ",
           "\n", "           ", 
          RowBox[{
           RowBox[{"ArcTan", " ", "@@", " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"emb", "[", 
               RowBox[{"[", "v", "]"}], "]"}], " ", "-", " ", 
              RowBox[{"emb", "[", 
               RowBox[{"[", "#", "]"}], "]"}]}], ")"}]}], " ", "&"}]}], 
         "]"}]}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"v", ",", " ", 
         RowBox[{"VertexList", "[", "g", "]"}]}], "}"}]}], "]"}], ";", "\n", 
     "       ", 
     RowBox[{
      RowBox[{"rightF", "[", "_", "]"}], " ", ":=", " ", "False"}], ";", "\n",
      "       ", 
     RowBox[{
      RowBox[{"Reap", "[", "\n", "         ", 
       RowBox[{"Table", "[", "\n", "           ", 
        RowBox[{
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"!", " ", 
            RowBox[{"rightF", "[", "e", "]"}]}], ",", "\n", "             ", 
           RowBox[{
            RowBox[{"s", " ", "=", " ", 
             RowBox[{"e", "[", 
              RowBox[{"[", "1", "]"}], "]"}]}], ";", "\n", "             ", 
            RowBox[{"t", " ", "=", " ", 
             RowBox[{"e", "[", 
              RowBox[{"[", "2", "]"}], "]"}]}], ";", "\n", "             ", 
            RowBox[{"initial", " ", "=", " ", "s"}], ";", "\n", 
            "             ", 
            RowBox[{"face", " ", "=", " ", 
             RowBox[{"{", "s", "}"}]}], ";", "\n", "             ", 
            RowBox[{"While", "[", 
             RowBox[{
              RowBox[{"t", " ", "=!=", " ", "initial"}], ",", "\n", 
              "               ", 
              RowBox[{
               RowBox[{
                RowBox[{"rightF", "[", 
                 RowBox[{"UndirectedEdge", "[", 
                  RowBox[{"s", ",", " ", "t"}], "]"}], "]"}], " ", "=", " ", 
                "True"}], ";", "\n", "               ", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"s", ",", " ", "t"}], "}"}], " ", "=", " ", 
                RowBox[{"nextCandidate", "[", 
                 RowBox[{"s", ",", " ", "t", ",", " ", 
                  RowBox[{"pAdj", "[", "t", "]"}]}], "]"}]}], ";", "\n", 
               "               ", 
               RowBox[{"face", " ", "=", " ", 
                RowBox[{"Join", "[", 
                 RowBox[{"face", ",", " ", 
                  RowBox[{"{", "s", "}"}]}], "]"}]}], ";"}]}], "\n", 
             "             ", "]"}], ";", "\n", "             ", 
            RowBox[{"Sow", "[", "face", "]"}], ";"}]}], "\n", "           ", 
          "]"}], ",", "\n", "         ", 
         RowBox[{"{", 
          RowBox[{"e", ",", " ", 
           RowBox[{"EdgeList", "[", "g", "]"}]}], "}"}]}], "]"}], "]"}], "[", 
      RowBox[{"[", 
       RowBox[{"2", ",", " ", "1"}], "]"}], "]"}]}]}], "\n", "     ", 
   "]"}]}]}], "Code",
 CellChangeTimes->{3.892122419666668*^9},
 CellLabel->
  "In[547]:=",ExpressionUUID->"59f3c85d-f9ff-4fd2-83fb-14f60e4ab98f"],

Cell[TextData[{
 "Obtain info from a dmccooey file: ",
 ButtonBox["LINK",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://mathematica.stackexchange.com/questions/284754/display-\
polyhedra-from-dmccooey-vertex-and-face-information/284757#284757"], None},
  ButtonNote->
   "https://mathematica.stackexchange.com/questions/284754/display-polyhedra-\
from-dmccooey-vertex-and-face-information/284757#284757"],
 "\n+1 for all vertice numbers in face-assignments as dmcooey starts from 0"
}], "Text",
 CellChangeTimes->{{3.892296916133979*^9, 3.8922969359695807`*^9}, {
  3.892297326441286*^9, 3.8922973285127*^9}, {3.892310764194189*^9, 
  3.89231076436042*^9}, {3.89256475781708*^9, 
  3.8925647584848948`*^9}},ExpressionUUID->"baa562b8-3809-45d6-ab4c-\
105f27cfde91"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"getDMMCCOOEYpolyhedron", " ", "=", " ", "\n", "  ", 
    RowBox[{
     RowBox[{"Import", "[", 
      RowBox[{
       RowBox[{"\"\<http://dmccooey.com/polyhedra/\>\"", " ", "<>", " ", "#", 
        " ", "<>", " ", "\"\<.txt\>\""}], ",", " ", "\"\<Lines\>\""}], "]"}], 
     " ", "&"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"split", " ", "=", "  ", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Length", "[", "#", "]"}], " ", "==", " ", "4"}], ",", " ", 
         RowBox[{"Drop", "[", 
          RowBox[{"#", ",", " ", 
           RowBox[{"{", "2", "}"}]}], "]"}], ",", " ", "#"}], "]"}], " ", 
       "&"}], " ", "@", "\n", "  ", 
      RowBox[{
       RowBox[{"Map", "[", 
        RowBox[{"DeleteCases", "[", 
         RowBox[{"\"\<Faces:\>\"", " ", "|", " ", "\"\<\>\""}], "]"}], "]"}], 
       " ", "@", "\n", "  ", 
       RowBox[{"Split", "[", 
        RowBox[{
         RowBox[{"Drop", "[", 
          RowBox[{"#", ",", " ", "2"}], "]"}], ",", " ", 
         RowBox[{
          RowBox[{"!", " ", 
           RowBox[{
            RowBox[{"StringStartsQ", "[", 
             
             RowBox[{"\"\<Faces\>\"", " ", "|", " ", "\"\<V0\>\"", " ", "|", 
              " ", "\"\<C0\>\""}], "]"}], " ", "@", " ", "#2"}]}], " ", 
          "&"}]}], "]"}]}]}], " ", "&"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"processStrings", " ", "=", " ", 
    RowBox[{"Map", " ", "@", " ", "\n", "  ", 
     RowBox[{"StringReplace", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"\"\<cbrt\>\"", " ", "->", " ", "\"\<CubeRoot\>\""}], ",", 
        " ", 
        RowBox[{"\"\<sqrt\>\"", " ", "->", " ", "\"\<Sqrt\>\""}], ",", " ", 
        "\n", "    ", 
        RowBox[{
         RowBox[{
          
          RowBox[{"\"\<(\>\"", " ", "~~", " ", "a__", " ", "~~", 
           " ", "\"\<)\>\""}], " ", "/;", " ", 
          RowBox[{"StringContainsQ", "[", 
           RowBox[{"a", ",", " ", "\"\<,\>\""}], "]"}]}], " ", ":>", " ", 
         RowBox[{"\"\<{\>\"", " ", "<>", " ", "a", " ", "<>", 
          " ", "\"\<}\>\""}]}], ",", "\n", "    ", 
        RowBox[{
         RowBox[{"\"\<=\>\"", " ", "~~", " ", 
          RowBox[{"a", " ", ":", " ", 
           RowBox[{"Shortest", "[", "__", "]"}]}], " ", "~~", " ", "\"\<=\>\"",
           " ", "~~", " ", "__"}], " ", ":>", " ", 
         RowBox[{"\"\<=\>\"", " ", "<>", " ", "a"}]}]}], "}"}], "]"}]}]}], 
   ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"coordsAndFaceIndices", " ", "=", " ", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Length", " ", "@", " ", "#"}], " ", "==", " ", "2"}], ",", 
         " ", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"0", ",", " ", "1"}], "}"}], " ", "+", " ", "#"}], ",", 
         "\n", "  ", 
         RowBox[{
          RowBox[{
           RowBox[{"{", 
            RowBox[{"#2", ",", " ", 
             RowBox[{"1", " ", "+", " ", "#3"}]}], "}"}], " ", "&"}], " ", "@@",
           " ", "#"}]}], "]"}], " ", "&"}], " ", "@", " ", 
      RowBox[{"ToExpression", "[", 
       RowBox[{"#", ",", " ", "TraditionalForm"}], "]"}]}], " ", "&"}]}], 
   ";"}], "\n", "\n"}], "\n", 
 RowBox[{
  RowBox[{"fromDMCCCOOEY", " ", "=", " ", 
   RowBox[{
   "coordsAndFaceIndices", " ", "@*", " ", "processStrings", " ", "@*", " ", 
    "\n", "  ", "split", " ", "@*", " ", "getDMMCCOOEYpolyhedron"}]}], 
  ";"}], "\n", 
 RowBox[{"\t"}]}], "Code",
 CellChangeTimes->{{3.8922969246128607`*^9, 3.892296965318348*^9}, {
   3.892309622074243*^9, 3.8923097693682203`*^9}, {3.8923098007037153`*^9, 
   3.892309803022616*^9}, {3.8923098728977823`*^9, 3.892309885792205*^9}, {
