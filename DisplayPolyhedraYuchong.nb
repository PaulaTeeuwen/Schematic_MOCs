 RowBox[{
  RowBox[{
   RowBox[{"view", "[", 
    RowBox[{"v_", ",", " ", "f_", ",", " ", "s_"}], "]"}], " ", ":=", " ", 
   "\n", "  ", 
   RowBox[{"Show", "[", 
    RowBox[{
     RowBox[{"Graphics3D", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"EdgeForm", "[", 
         RowBox[{"{", "Thick", "}"}], "]"}], ",", " ", "\n", "  ", 
        RowBox[{"Polygon", " ", "/@", " ", 
         RowBox[{"Map", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"v", "[", 
             RowBox[{"[", "#1", "]"}], "]"}], " ", "&"}], " ", ",", " ", "f", 
           ",", " ", 
           RowBox[{"{", "2", "}"}]}], "]"}]}], ",", " ", "Black", ",", " ", 
        RowBox[{"Sphere", "[", 
         RowBox[{"v", ",", " ", "s"}], "]"}]}], "}"}], "]"}], ",", "\n", "  ", 
     RowBox[{"PlotRange", "->", " ", "All"}], ",", 
     RowBox[{"Boxed", " ", "->", " ", "False"}]}], "]"}]}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"hexToRGB", " ", "=", " ", 
   RowBox[{
    RowBox[{"RGBColor", " ", "@@", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"IntegerDigits", "[", 
        RowBox[{
         RowBox[{
         "#", " ", "~", "StringDrop", "~", " ", "1", " ", "~", "FromDigits", "~",
           " ", "16"}], ",", " ", "256", ",", " ", "3"}], "]"}], "/", 
       "255."}], ")"}]}], " ", "&"}]}], ";"}], "\n"}], "Code",
